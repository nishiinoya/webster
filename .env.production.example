# Copy to .env.production and fill in real values. NEVER commit .env.production.
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# --- Database (use a strong password) ---
POSTGRES_USER=webster
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=webster

# --- Object storage (MinIO root creds; used for both MinIO and the API's S3 client) ---
S3_ACCESS_KEY=change-me-access-key
S3_SECRET_KEY=change-me-strong-secret
S3_BUCKET=webster

# --- Public URLs (what the browser talks to) ---
# These are baked into the web build. Use your real public API/WS origin.
CORS_ORIGIN=https://app.yourdomain.com
NEXT_PUBLIC_WEBSTER_API_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_WEBSTER_WS_URL=https://api.yourdomain.com

# --- Auth0 (SPA application + API) ---
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://api.yourdomain.com
AUTH0_MANAGEMENT_CLIENT_ID=your-machine-to-machine-client-id
AUTH0_MANAGEMENT_CLIENT_SECRET=your-machine-to-machine-client-secret
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.eu.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-spa-client-id
NEXT_PUBLIC_AUTH0_AUDIENCE=https://api.yourdomain.com
NEXT_PUBLIC_AUTH0_REDIRECT_URI=https://app.yourdomain.com/callback

# --- Stripe (LIVE key + the signing secret from your dashboard webhook endpoint) ---
# In the Stripe dashboard add a webhook endpoint pointing to
#   https://api.yourdomain.com/api/subscriptions/webhook
# (events: checkout.session.completed, customer.subscription.updated,
#  customer.subscription.deleted, invoice.paid)
# then copy its signing secret into STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Inline plan amounts — no dashboard Product/Price needed. Optional; defaults shown.
STRIPE_PRODUCT_NAME=Webster Pro
STRIPE_CURRENCY=usd
STRIPE_MONTHLY_AMOUNT_CENTS=999
STRIPE_YEARLY_AMOUNT_CENTS=9900
